# ── ScannApp Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string-50-chars
DEBUG=True
ALLOWED_HOSTS=*

# CORS — add your GitHub Pages URL
# e.g. https://yourusername.github.io
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_ALL=True

# Google Sheets
# The ID is in your sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Path to your downloaded service account JSON key
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Tesseract binary path
# Linux/Ubuntu: /usr/bin/tesseract  (after: sudo apt install tesseract-ocr)
# Windows: C:/Program Files/Tesseract-OCR/tesseract.exe
# Mac: /usr/local/bin/tesseract     (after: brew install tesseract)
TESSERACT_CMD=/usr/bin/tesseract
